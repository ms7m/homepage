---
import { getCollection } from "astro:content";
import "../styles/global.css";

const posts = (await getCollection("posts"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Mustafa's blog" />
    <title>mikka — blog</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <h1 class="site-title">blog</h1>
        <a href="https://mikka.link" class="back-link">mikka.link ↗</a>
      </div>
    </header>

    <main>
      {posts.length === 0 ? (
        <p class="empty">No posts yet.</p>
      ) : (
        <ul class="post-list">
          {posts.map((post) => (
            <li>
              <a href={`/${post.slug}`} class="post-link">
                <span class="post-date">
                  {post.data.pubDate.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" })}
                </span>
                <span class="post-title">{post.data.title}</span>
                {post.data.description && (
                  <span class="post-desc">{post.data.description}</span>
                )}
              </a>
            </li>
          ))}
        </ul>
      )}
    </main>
  </body>
</html>

<style>
  header {
    padding: 32px 48px 24px;
    border-bottom: 1px solid hsl(var(--border));
  }

  .header-inner {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
  }

  .site-title {
    font-family: "EditorialNew", Georgia, serif;
    font-size: 2.5rem;
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1;
    color: hsl(var(--foreground));
  }

  .back-link {
    font-size: 0.75rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    text-decoration: none;
    transition: color 0.15s;
  }

  .back-link:hover {
    color: hsl(var(--foreground));
  }

  main {
    max-width: 680px;
    margin: 0 auto;
    padding: 48px 48px 80px;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .post-link {
    display: grid;
    grid-template-columns: 110px 1fr;
    grid-template-rows: auto auto;
    gap: 0 20px;
    padding: 20px 0;
    border-bottom: 1px solid hsl(var(--border));
    text-decoration: none;
    color: inherit;
    transition: opacity 0.15s;
  }

  .post-link:hover {
    opacity: 0.7;
  }

  .post-date {
    font-size: 0.7rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    padding-top: 3px;
    grid-row: 1;
  }

  .post-title {
    font-family: "EditorialNew", Georgia, serif;
    font-size: 1.25rem;
    font-weight: 400;
    letter-spacing: -0.02em;
    color: hsl(var(--foreground));
    grid-column: 2;
    grid-row: 1;
  }

  .post-desc {
    font-size: 0.8rem;
    color: hsl(var(--muted-foreground));
    grid-column: 2;
    grid-row: 2;
    margin-top: 4px;
  }

  .empty {
    font-size: 0.8rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    padding: 80px 0;
  }

  @media (max-width: 600px) {
    header { padding: 24px; }
    main { padding: 32px 24px 60px; }

    .post-link {
      grid-template-columns: 1fr;
    }

    .post-date {
      grid-row: 2;
      margin-top: 4px;
    }

    .post-title {
      grid-column: 1;
      grid-row: 1;
    }

    .post-desc {
      grid-column: 1;
      grid-row: 3;
    }
  }
</style>
