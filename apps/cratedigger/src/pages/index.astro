---
import "../styles/global.css";
import AlbumGrid from "../components/AlbumGrid.vue";
import NowPlaying from "../components/NowPlaying.vue";
import LastFm from "../components/LastFm.vue";

import { getAlbumsPage } from "@mikka/cloudflare-utils";
import type { CratediggerEnv } from "@mikka/cloudflare-utils";

const PAGE_SIZE = 24;
const API_URL = import.meta.env.PUBLIC_API_URL ?? "https://api.mikka.link";

let initialAlbums: Awaited<ReturnType<typeof getAlbumsPage>> = { albums: [], total: 0, hasMore: false };
let scrobbles: string | null = null;

try {
  const env = (Astro.locals as { runtime: { env: CratediggerEnv } }).runtime.env;
  const [albumsResult, lastfmRes] = await Promise.all([
    getAlbumsPage(env, 0, PAGE_SIZE),
    fetch(`${API_URL}/lastfm`),
  ]);
  initialAlbums = albumsResult;
  const lastfmData = await lastfmRes.json() as any;
  scrobbles = lastfmData?.user?.totalScrobbles ?? null;
} catch {
  // dev mode without wrangler
}
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="A crate of music I love." />
    <title>cratedigger</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://cratedigger.mikka.link" />
    <meta property="og:site_name" content="mikka" />
    <meta property="og:title" content="cratedigger" />
    <meta property="og:description" content="A crate of music I love." />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:creator" content="mikka" />
    <meta name="twitter:title" content="cratedigger" />
    <meta name="twitter:description" content="A crate of music I love." />
  </head>
  <body>
    <header>
      <div class="header-inner">
        <div class="header-left">
          <h1 class="site-title">cratedigger</h1>
          <span class="record-count">{initialAlbums.total} records</span>
        </div>
        <div class="header-right">
          <LastFm scrobbles={scrobbles} />
          <NowPlaying client:only="vue" />
        </div>
      </div>
      <p class="subtitle">some music i think you should listen to — <a href="https://mikka.link" class="subtitle-link">check out my website</a></p>
    </header>

    <main>
      <AlbumGrid
        client:only="vue"
        initialAlbums={initialAlbums.albums}
        total={initialAlbums.total}
        apiUrl={API_URL}
      />
    </main>
  </body>
</html>

<style>
  header {
    padding: 32px 32px 24px;
    border-bottom: 1px solid hsl(var(--border));
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
  }

  .header-right {
    display: flex;
    align-items: stretch;
    gap: 8px;
    min-width: 0;
  }

  .header-left {
    display: flex;
    align-items: baseline;
    gap: 16px;
  }

  .site-title {
    font-family: "EditorialNew", Georgia, serif;
    font-size: 2.5rem;
    font-weight: 400;
    letter-spacing: -0.03em;
    line-height: 1;
    color: hsl(var(--foreground));
  }

  .record-count {
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
  }

  .subtitle {
    margin-top: 8px;
    font-size: 0.8rem;
    color: hsl(var(--muted-foreground));
  }

  .subtitle-link {
    color: hsl(var(--muted-foreground));
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: color 0.15s;
  }

  .subtitle-link:hover {
    color: hsl(var(--foreground));
  }

</style>
